# Copy to .env.local (never commit real keys).

# --- Notion content (AI news + LinkedIn posts) ---
# Until these are set, the site serves bundled sample data.
NOTION_API_KEY=
NOTION_NEWS_DB_ID=
NOTION_LINKEDIN_DB_ID=

# --- Booking enquiries ---
# Resend (resend.com) API key. Until set, enquiries are logged server-side only.
RESEND_API_KEY=
# From-address on a Resend-verified domain. The account's verified domain is
# instituteof.ai; switch to enquiry@timfrankandersen.com once that domain is
# verified in Resend after the DNS cutover.
ENQUIRY_FROM=enquiry@instituteof.ai
